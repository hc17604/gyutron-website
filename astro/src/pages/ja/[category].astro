---
import ProductPage from '../../components/ProductPage.astro';
import { GYUTRON_PRODUCTS } from '../../data/products.en.js';

export function getStaticPaths() {
  return Object.keys(GYUTRON_PRODUCTS)
    .filter((k) => (GYUTRON_PRODUCTS as any)[k].products?.length && !(GYUTRON_PRODUCTS as any)[k].redirectTo)
    .map((category) => ({ params: { category } }));
}
const { category } = Astro.params;
---
<ProductPage locale="ja" category={category!} />
