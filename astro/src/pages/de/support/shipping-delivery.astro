<SupportPage
  locale="de"
  path="/support/shipping-delivery.html"
  title="Versand & Lieferung | GYUTRON Support"
  description="Wie GYUTRON Industriehardware weltweit versendet — Versandursprung, Auftragsabwicklung, Lieferzeiten, Incoterms, Zoll und Abgaben, Industrieverpackung, Sendungsverfolgung, Teillieferungen und Liefervorfälle für B2B- und grenzüberschreitende Aufträge."
  eyebrow="Hilfe & Support"
  heading="Versand & Lieferung"
  crumb="Versand & Lieferung"
