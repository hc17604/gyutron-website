---
import ProductPage from '../components/ProductPage.astro';
import MetaRedirect from '../components/MetaRedirect.astro';
import { t } from '../i18n';
import { GYUTRON_PRODUCTS } from '../data/products.en.js';

export function getStaticPaths() {
  return Object.keys(GYUTRON_PRODUCTS)
    .filter((k) => (GYUTRON_PRODUCTS as any)[k].products?.length || (GYUTRON_PRODUCTS as any)[k].redirectTo)
    .map((category) => ({ params: { category } }));
}
const { category } = Astro.params;
const redirectTo: string | undefined = (GYUTRON_PRODUCTS as any)[category!].redirectTo;
---
{redirectTo
  ? <MetaRedirect locale="en" target={`/${redirectTo}.html`} title={t('en', `seo.${category}.title`)} />
  : <ProductPage locale="en" category={category!} />}
