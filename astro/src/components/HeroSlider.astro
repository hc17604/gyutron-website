---
/*
 * HeroSlider.astro — PPT 分层时间轴 Hero(工业风,无第三方库,用 Web Animations API)
 * ----------------------------------------------------------------------------
 * 每屏由多个独立图层组成(背景/遮罩/色块/kicker/标题/副标题/CTA/标签/产品图/标签卡),
 * 各自错峰淡入+位移/缩放;一屏全部图层 finished 后停留 HOLD,整屏淡出再切下一屏
 * (切页由动画完成驱动,不是盲目 setInterval)。
 * 文案走 t(locale,key)(build 时);结构/图片/动画参数在 src/data/heroSlides.ts。
 * 可调参数在客户端 <script> 顶部 CONFIG;文字层入场节奏在下方 SEQ。
 */
import { t, localizeUrl, type Locale } from '../i18n';
import { HERO_SLIDES } from '../data/heroSlides';
interface Props { locale: Locale; }
const { locale } = Astro.props;

// 文字层入场节奏(delay/dur 单位 ms;from 为起始位移/缩放/透明度)
const SEQ = {
  bg:      { from: { o: 0, scale: 1.06 }, delay: 0,    dur: 1200 },
  overlay: { from: { o: 0 },              delay: 150,  dur: 700 },
  bars:    { from: { o: 0, x: -16 },      delay: 320,  dur: 600 },
  kicker:  { from: { o: 0, y: 20 },       delay: 440,  dur: 620 },
  title:   { from: { o: 0, y: 32 },       delay: 660,  dur: 780 },
  sub:     { from: { o: 0, y: 24 },       delay: 1000, dur: 700 },
  cta:     { from: { o: 0, y: 18 },       delay: 1300, dur: 640 },
  tags:    { from: { o: 0, y: 16 },       delay: 1580, dur: 600 },
  card:    { from: { o: 0, y: 20, scale: 0.96 }, delay: 2150, dur: 720 },
};
const A = (cfg: unknown) => JSON.stringify(cfg);
const visFrom = (dir: string) =>
  dir === 'right' ? { o: 0, x: 48 } :
  dir === 'left'  ? { o: 0, x: -48 } :
  dir === 'up'    ? { o: 0, y: 40 } :
  dir === 'down'  ? { o: 0, y: -40 } :
                    { o: 0, scale: 0.9 };
const href = (h: string) => (h.startsWith('#') ? h : localizeUrl(locale, h));
---
<section class="hsl" aria-label="GYUTRON featured solutions" aria-roledescription="carousel">
  <div class="hsl-track">
    {HERO_SLIDES.map((s, i) => (
      <article class={`hsl-slide${i === 0 ? ' is-active' : ''}`} style={`--accent:${s.accent}`} aria-hidden={i !== 0 ? 'true' : 'false'} aria-roledescription="slide">
        <div class="hsl-bg" data-layer data-anim={A(SEQ.bg)} style={`background-image:url('${s.bg}')`}></div>
        <div class="hsl-overlay" data-layer data-anim={A(SEQ.overlay)}></div>

        <div class="hsl-inner">
          <div class="hsl-copy">
            <div class="hsl-bars" data-layer data-anim={A(SEQ.bars)} aria-hidden="true"><span></span><span></span><span></span></div>
            <span class="hsl-kicker" data-layer data-anim={A(SEQ.kicker)}>{t(locale, s.kickerKey)}</span>
            <h1 class="hsl-title" data-layer data-anim={A(SEQ.title)}>{t(locale, s.titleKey)}</h1>
            <p class="hsl-sub" data-layer data-anim={A(SEQ.sub)}>{t(locale, s.subKey)}</p>
            <div class="hsl-ctarow" data-layer data-anim={A(SEQ.cta)}>
              <a class="hsl-cta" href={href(s.ctaHref)}>{t(locale, s.ctaKey)} <i class="fa-solid fa-arrow-right"></i></a>
              {s.cta2Key && <a class="hsl-cta hsl-cta--ghost" href={href(s.cta2Href!)}>{t(locale, s.cta2Key)}</a>}
            </div>
            <div class="hsl-tags" data-layer data-anim={A(SEQ.tags)} aria-hidden="true">
              {s.tags.map((tag) => (<span><i class={tag.icon}></i> {tag.key ? t(locale, tag.key) : tag.text}</span>))}
            </div>
          </div>

          <div class="hsl-visual" aria-hidden="true">
            {s.visuals.map((v) => (
              <img class={`hsl-img hsl-img--${v.pos}`} src={v.src} alt="" loading={i === 0 ? 'eager' : 'lazy'} decoding="async"
                   data-layer data-anim={A({ from: visFrom(v.dir), delay: Math.round(v.delay * 1000), dur: Math.round(v.dur * 1000) })} />
            ))}
            {s.cardKey && (
              <div class="hsl-card" data-layer data-anim={A(SEQ.card)}>
                <strong>{t(locale, s.cardKey)}</strong><span>{t(locale, s.cardSubKey!)}</span>
              </div>
            )}
          </div>
        </div>
      </article>
    ))}
  </div>

  <div class="hsl-dots" role="tablist" aria-label="Slides">
    {HERO_SLIDES.map((s, i) => (
      <button class={`hsl-dot${i === 0 ? ' is-active' : ''}`} type="button" role="tab" data-dot={i} aria-selected={i === 0 ? 'true' : 'false'} aria-label={t(locale, s.titleKey)}></button>
    ))}
  </div>

  <script is:inline>
    (function () {
      var CONFIG = { hold: 2800, fade: 600, autoplay: true, pauseOnHover: true, loop: true };
      var root = document.querySelector('.hsl');
      if (!root) return;
      var slides = Array.prototype.slice.call(root.querySelectorAll('.hsl-slide'));
      var dots = Array.prototype.slice.call(root.querySelectorAll('.hsl-dot'));
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduce) root.classList.add('is-anim');
      var EASE = 'cubic-bezier(0.22, 1, 0.36, 1)';

      var current = 0, anims = [], holdTimer = null, fadeAnim = null;
      var phase = 'idle', paused = false, holdRemain = CONFIG.hold, holdStart = 0;

      function tf(f) { var s = ''; if (f.x != null) s += 'translateX(' + f.x + 'px) '; if (f.y != null) s += 'translateY(' + f.y + 'px) '; if (f.scale != null) s += 'scale(' + f.scale + ') '; return s.trim() || 'none'; }
      function kf(f) { return [{ opacity: f.o != null ? f.o : 1, transform: tf(f) }, { opacity: 1, transform: 'none' }]; }
      function layersOf(slide) { return Array.prototype.slice.call(slide.querySelectorAll('[data-layer]')); }
      function resetLayers(slide) { layersOf(slide).forEach(function (l) { l.style.opacity = ''; l.style.transform = ''; }); }
      function setDots(i) { dots.forEach(function (d, k) { d.classList.toggle('is-active', k === i); d.setAttribute('aria-selected', String(k === i)); }); }

      function clearTimers() { if (holdTimer) { clearTimeout(holdTimer); holdTimer = null; } }
      function killAnims() { anims.forEach(function (a) { try { a.cancel(); } catch (e) {} }); anims = []; }

      function playSlide(i) {
        current = i;
        slides.forEach(function (s, k) { s.classList.toggle('is-active', k === i); s.setAttribute('aria-hidden', String(k !== i)); });
        setDots(i);
        var slide = slides[i];
        slide.style.opacity = '1';
        resetLayers(slide);
        if (reduce) { phase = 'hold'; scheduleHold(); return; }
        phase = 'enter';
        anims = layersOf(slide).map(function (l) {
          var cfg = {}; try { cfg = JSON.parse(l.getAttribute('data-anim') || '{}'); } catch (e) {}
          return l.animate(kf(cfg.from || {}), { duration: cfg.dur || 700, delay: cfg.delay || 0, easing: EASE, fill: 'both' });
        });
        Promise.all(anims.map(function (a) { return a.finished; })).then(function () {
          if (phase === 'enter' && current === i) scheduleHold();
        }).catch(function () {});
      }

      function scheduleHold() {
        phase = 'hold'; holdRemain = CONFIG.hold;
        if (CONFIG.autoplay && !paused) { holdStart = performance.now(); holdTimer = setTimeout(advance, holdRemain); }
      }
      function advance() { if (!CONFIG.loop && current === slides.length - 1) return; goTo((current + 1) % slides.length); }

      function goTo(j) {
        if (j === current && phase !== 'idle') return;
        clearTimers(); killAnims();
        if (fadeAnim) { try { fadeAnim.cancel(); } catch (e) {} fadeAnim = null; }
        phase = 'fade';
        var cur = slides[current];
        fadeAnim = cur.animate([{ opacity: 1 }, { opacity: 0 }], { duration: reduce ? 0 : CONFIG.fade, easing: 'ease', fill: 'both' });
        fadeAnim.finished.then(function () {
          cur.classList.remove('is-active'); cur.setAttribute('aria-hidden', 'true'); cur.style.opacity = ''; resetLayers(cur);
          fadeAnim = null; playSlide(j);
        }).catch(function () {});
      }

      function pause() {
        if (paused) return; paused = true;
        if (phase === 'enter') { anims.forEach(function (a) { try { a.pause(); } catch (e) {} }); }
        else if (phase === 'hold' && holdTimer) { clearTimeout(holdTimer); holdTimer = null; holdRemain = Math.max(0, holdRemain - (performance.now() - holdStart)); }
      }
      function resume() {
        if (!paused) return; paused = false;
        if (phase === 'enter') { anims.forEach(function (a) { try { a.play(); } catch (e) {} }); }
        else if (phase === 'hold' && !holdTimer && CONFIG.autoplay) { holdStart = performance.now(); holdTimer = setTimeout(advance, holdRemain); }
      }

      dots.forEach(function (d, i) { d.addEventListener('click', function () { goTo(i); }); });
      var prev = root.querySelector('.hsl-arrow--prev'), next = root.querySelector('.hsl-arrow--next');
      if (prev) prev.addEventListener('click', function () { goTo((current - 1 + slides.length) % slides.length); });
      if (next) next.addEventListener('click', function () { goTo((current + 1) % slides.length); });
      if (CONFIG.pauseOnHover) { root.addEventListener('pointerenter', pause); root.addEventListener('pointerleave', resume); root.addEventListener('focusin', pause); root.addEventListener('focusout', resume); }

      playSlide(0);
    })();
  </script>
</section>
