---
/*
 * HeroSlider.astro — PPT 分层 Hero,三屏三版式(solutions / grid / product)
 * ----------------------------------------------------------------------------
 * 显隐:.is-active + CSS opacity/visibility 过渡(整屏交叉淡出)。
 * 入场:每个 [data-layer] 用 @keyframes hslIn,参数走内联 --fx/--fy/--fs/--delay/--dur。
 * 切页:JS 等 data-entrance + HOLD 后切下一屏;圆点点击、聚焦暂停(hover 不暂停)、循环。
 * 数据:结构/图片在 src/data/heroSlides.ts;'product' 屏按 locale 读 products.{locale}.js。
 *   s1 solutions:左能力文案 + 右行业照片拼贴;s2 grid:左文案 + 右产品抠图网格;
 *   s3 product:左单品抠图大图(透明) + 右型号/规格/标签。
 */
import { t, localizeUrl, type Locale } from '../i18n';
import { HERO_SLIDES } from '../data/heroSlides';
import { GYUTRON_PRODUCTS as P_EN } from '../data/products.en.js';
import { GYUTRON_PRODUCTS as P_DE } from '../data/products.de.js';
import { GYUTRON_PRODUCTS as P_JA } from '../data/products.ja.js';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const PRODUCTS: any = ({ en: P_EN, de: P_DE, ja: P_JA } as any)[locale] || P_EN;

const SEQ = {
  bg:      { x: 0, y: 0,  s: 1.06, delay: 0,    dur: 1500 },
  overlay: { x: 0, y: 0,  s: 1,    delay: 140,  dur: 780 },
  kicker:  { x: 0, y: 20, s: 1,    delay: 460,  dur: 740 },
  title:   { x: 0, y: 32, s: 1,    delay: 700,  dur: 880 },
  sub:     { x: 0, y: 24, s: 1,    delay: 1080, dur: 820 },
  cta:     { x: 0, y: 18, s: 1,    delay: 1440, dur: 740 },
  tags:    { x: 0, y: 16, s: 1,    delay: 1700, dur: 700 },
  card:    { x: 0, y: 20, s: 0.96, delay: 2050, dur: 800 },
};
type F = { x: number; y: number; s: number; delay: number; dur: number };
const ls = (f: F) => `--fx:${f.x}px;--fy:${f.y}px;--fs:${f.s};--delay:${f.delay}ms;--dur:${f.dur}ms`;
const li = (base: number, i: number, step: number, dur: number, fy = 18) => `--fx:0px;--fy:${fy}px;--fs:1;--delay:${base + i * step}ms;--dur:${dur}ms`;
// 产品屏(s3):用户要求"先产品后文字" —— 产品图最早入场(250ms),文字随后错峰
const PSEQ = {
  img:    { x: -44, y: 0,  s: 0.94, delay: 250,  dur: 1050 },
  kicker: { x: 0,   y: 20, s: 1,    delay: 1150, dur: 600 },
  title:  { x: 0,   y: 30, s: 1,    delay: 1320, dur: 680 },
  sub:    { x: 0,   y: 22, s: 1,    delay: 1560, dur: 640 },
  specs:  { x: 0,   y: 16, s: 1,    delay: 1790, dur: 600 },
  tags:   { x: 0,   y: 14, s: 1,    delay: 1970, dur: 560 },
  cta:    { x: 0,   y: 18, s: 1,    delay: 2140, dur: 620 },
};
const href = (h?: string) => (h && h.startsWith('#') ? h : localizeUrl(locale, h || '#'));
const entrance = 3300;

const slides = HERO_SLIDES.map((s) => {
  if (s.layout === 'product') {
    const cat: any = PRODUCTS[s.productCat as string] || {};
    const m: any = (cat.products || []).find((p: any) => p.name === s.productName) || (cat.products || [])[0] || {};
    return { ...s, _eyebrow: cat.eyebrow || '', _title: s.productName || cat.title || '', _sub: m.summary || cat.intro || '', _specs: Object.values(m.specs || {}), _tags: m.tags || [], _dot: s.productName || '' };
  }
  return { ...s, _dot: s.titleKey ? t(locale, s.titleKey) : s.id };
}) as any[];
---
<section class="hsl" data-entrance={entrance} aria-label="GYUTRON featured solutions" aria-roledescription="carousel">
  <div class="hsl-track">
    {slides.map((s, i) => (
      <article class={`hsl-slide hsl-slide--${s.layout}${i === 0 ? ' is-active' : ''}`} style={`--accent:${s.accent}`} aria-hidden={i !== 0 ? 'true' : 'false'} aria-roledescription="slide">
        <div class="hsl-bg" data-layer style={`background-image:url('${s.bg}');${ls(SEQ.bg)}`}></div>
        <div class="hsl-overlay" data-layer style={ls(SEQ.overlay)}></div>
        <div class="hsl-inner">

          {s.layout === 'solutions' && (
            <Fragment>
              <div class="hsl-copy">
                <span class="hsl-kicker" data-layer style={ls(SEQ.kicker)}>{t(locale, s.kickerKey)}</span>
                <h1 class="hsl-title" data-layer style={ls(SEQ.title)}>{t(locale, s.titleKey)}</h1>
                <p class="hsl-sub" data-layer style={ls(SEQ.sub)}>{t(locale, s.subKey)}</p>
                <div class="hsl-ctarow" data-layer style={ls(SEQ.cta)}>
                  <a class="hsl-cta" href={href(s.ctaHref)}>{t(locale, s.ctaKey)} <i class="fa-solid fa-arrow-right"></i></a>
                  {s.cta2Key && <a class="hsl-cta hsl-cta--ghost" href={href(s.cta2Href)}>{t(locale, s.cta2Key)}</a>}
                </div>
              </div>
              <div class="hsl-collage" aria-hidden="true">
                {(s.industries || []).map((ind: any, k: number) => (
                  <figure class={`hsl-col hsl-col--${k}`} data-layer style={li(1500, k, 190, 900, 22)}>
                    <img src={ind.img} alt="" loading={i === 0 ? 'eager' : 'lazy'} decoding="async" />
                    <figcaption>{t(locale, ind.labelKey)}</figcaption>
                  </figure>
                ))}
              </div>
            </Fragment>
          )}

          {s.layout === 'grid' && (
            <Fragment>
              <div class="hsl-copy">
                <span class="hsl-kicker" data-layer style={ls(SEQ.kicker)}>{t(locale, s.kickerKey)}</span>
                <h1 class="hsl-title" data-layer style={ls(SEQ.title)}>{t(locale, s.titleKey)}</h1>
                <p class="hsl-sub" data-layer style={ls(SEQ.sub)}>{t(locale, s.subKey)}</p>
                <div class="hsl-ctarow" data-layer style={ls(SEQ.cta)}>
                  <a class="hsl-cta" href={href(s.ctaHref)}>{t(locale, s.ctaKey)} <i class="fa-solid fa-arrow-right"></i></a>
                </div>
              </div>
              <div class="hsl-pgrid" aria-hidden="true">
                {(s.products || []).map((src: string, k: number) => (
                  <div class="hsl-pcell" data-layer style={li(1380, k, 85, 760, 16)}>
                    <img src={src} alt="" loading={i === 0 ? 'eager' : 'lazy'} decoding="async" />
                  </div>
                ))}
              </div>
            </Fragment>
          )}

          {s.layout === 'product' && (
            <Fragment>
              <div class="hsl-prod-visual" aria-hidden="true">
                <img class="hsl-prod-img" src={s.productImg} alt="" loading={i === 0 ? 'eager' : 'lazy'} decoding="async" data-layer style={ls(PSEQ.img)} />
              </div>
              <div class="hsl-copy hsl-copy--product">
                <span class="hsl-kicker" data-layer style={ls(PSEQ.kicker)}>{s._eyebrow}</span>
                <h1 class="hsl-title" data-layer style={ls(PSEQ.title)}>{s._title}</h1>
                <p class="hsl-sub" data-layer style={ls(PSEQ.sub)}>{s._sub}</p>
                <ul class="hsl-specs" data-layer style={ls(PSEQ.specs)}>
                  {(s._specs || []).map((v: any) => (<li>{v}</li>))}
                </ul>
                <div class="hsl-ptags" data-layer style={ls(PSEQ.tags)}>
                  {(s._tags || []).map((tg: any) => (<span>{tg}</span>))}
                </div>
                <div class="hsl-ctarow" data-layer style={ls(PSEQ.cta)}>
                  <a class="hsl-cta" href={href(s.ctaHref)}>{t(locale, s.ctaKey)} <i class="fa-solid fa-arrow-right"></i></a>
                </div>
              </div>
            </Fragment>
          )}

        </div>
      </article>
    ))}
  </div>

  <div class="hsl-dots" role="tablist" aria-label="Slides">
    {slides.map((s, i) => (
      <button class={`hsl-dot${i === 0 ? ' is-active' : ''}`} type="button" role="tab" data-dot={i} aria-selected={i === 0 ? 'true' : 'false'} aria-label={s._dot || s.id}></button>
    ))}
  </div>

  <script is:inline>
    (function () {
      var CONFIG = { hold: 3300, autoplay: true, pauseOnHover: false, loop: true };
      var root = document.querySelector('.hsl');
      if (!root) return;
      var slides = Array.prototype.slice.call(root.querySelectorAll('.hsl-slide'));
      var dots = Array.prototype.slice.call(root.querySelectorAll('.hsl-dot'));
      if (!slides.length) return;
      var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var entrance = parseInt(root.getAttribute('data-entrance'), 10) || 3300;
      var cycle = entrance + CONFIG.hold;
      var current = 0, timer = null, paused = false, remain = cycle, startTs = 0;

      function show(i) {
        i = (i + slides.length) % slides.length;
        slides.forEach(function (s, k) { s.classList.toggle('is-active', k === i); s.setAttribute('aria-hidden', String(k !== i)); });
        dots.forEach(function (d, k) { d.classList.toggle('is-active', k === i); d.setAttribute('aria-selected', String(k === i)); });
        void slides[i].offsetWidth;
        current = i;
        schedule(cycle);
      }
      function schedule(ms) {
        if (timer) { clearTimeout(timer); timer = null; }
        if (reduce || !CONFIG.autoplay || paused) return;
        remain = ms; startTs = performance.now();
        timer = setTimeout(function () { show(current + 1); }, ms);
      }
      function pause() {
        if (paused) return; paused = true;
        if (timer) { clearTimeout(timer); timer = null; remain = Math.max(0, remain - (performance.now() - startTs)); }
      }
      function resume() {
        if (!paused) return; paused = false;
        if (CONFIG.autoplay && !timer) schedule(remain);
      }

      dots.forEach(function (d, i) { d.addEventListener('click', function () { show(i); }); });
      root.addEventListener('focusin', pause); root.addEventListener('focusout', resume);
      if (CONFIG.pauseOnHover) {
        root.addEventListener('pointerenter', pause); root.addEventListener('pointerleave', resume);
      }
      slides[0].classList.remove('is-active'); void slides[0].offsetWidth;
      show(0);
    })();
  </script>
</section>
