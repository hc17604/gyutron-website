---
import Layout from '../layouts/Layout.astro';
import { t, localizeUrl, type Locale } from '../i18n';
import Footer from './Footer.astro';
import { canonicalUrl } from '../utils/seo';
import { createOrganizationJsonLd, breadcrumbFromHome } from '../utils/structured-data';
import { TURNSTILE_SITE_KEY, TURNSTILE_SCRIPT_URL } from '../config/turnstile';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const path = '/support/contact.html';
const structuredData = [
  createOrganizationJsonLd(),
  breadcrumbFromHome(locale, [
    { name: t(locale, 'fnav.support'), url: canonicalUrl(locale, '/support.html') },
    { name: t(locale, 'supc.title'), url: canonicalUrl(locale, path) },
  ]),
];
// Issue types — VALUES are the worker's stable enum (schemas.mjs ISSUE_TYPES), labels localized.
const ISSUE_OPTIONS = [
  { value: 'defect', labelKey: 'supc.it.defect' },
  { value: 'how_to', labelKey: 'supc.it.how_to' },
  { value: 'rma', labelKey: 'supc.it.rma' },
  { value: 'integration', labelKey: 'supc.it.integration' },
  { value: 'documentation', labelKey: 'supc.it.documentation' },
  { value: 'other', labelKey: 'supc.it.other' },
];
const STATUS = ({
  en: {
    sending: 'Sending your support request...',
    success: 'Thanks. Your support request has been received — our engineers will respond by email.',
    error: 'The request could not be sent right now.',
    fallback: 'Please email info@gyutron.com or use WhatsApp: +852 69509801.',
  },
  de: {
    sending: 'Ihre Support-Anfrage wird gesendet …',
    success: 'Danke. Ihre Support-Anfrage ist eingegangen – unsere Ingenieure antworten per E-Mail.',
    error: 'Die Anfrage konnte derzeit nicht gesendet werden.',
    fallback: 'Bitte schreiben Sie an info@gyutron.com oder nutzen Sie WhatsApp: +852 69509801.',
  },
  ja: {
    sending: 'サポート依頼を送信しています…',
    success: 'ありがとうございます。サポート依頼を受け付けました。エンジニアがメールで回答します。',
    error: '現在リクエストを送信できませんでした。',
    fallback: 'info@gyutron.com までメールするか、WhatsApp: +852 69509801 をご利用ください。',
  },
} as const)[locale];
---
<Layout
  locale={locale}
  path={path}
  title={t(locale, 'seo.support-contact.title')}
  description={t(locale, 'seo.support-contact.desc')}
  ogTitle={t(locale, 'seo.support-contact.ogtitle')}
  ogDescription={t(locale, 'seo.support-contact.ogdesc')}
  pageCss={["/contact-page.css", "/mobile-navigation.css"]}
  structuredData={structuredData}
>
  <main>
    <section class="contact-hero">
      <div class="container">
        <span class="eyebrow">{t(locale, "supc.eyebrow")}</span>
        <h1>{t(locale, "supc.title")}</h1>
        <p>{t(locale, "supc.sub")}</p>
      </div>
    </section>

    <section class="container contact-layout" aria-label={t(locale, "supc.title")}>
      <aside class="info-panel">
        <div class="section-label">{t(locale, "fnav.support")}</div>
        <h2>{t(locale, "supc.info.title")}</h2>
        <p>{t(locale, "supc.info.text")}</p>
        <div class="contact-methods">
          <a class="contact-method" href="mailto:info@gyutron.com">
            <i class="fa-solid fa-envelope"></i>
            <span><strong>{t(locale, "main.410")}</strong><span>info@gyutron.com</span></span>
          </a>
          <a class="contact-method" href="https://wa.me/85269509801">
            <i class="fa-brands fa-whatsapp"></i>
            <span><strong>WhatsApp</strong><span>+852 69509801</span></span>
          </a>
          <a class="contact-method" href={localizeUrl(locale, '/support/faq.html')}>
            <i class="fa-solid fa-circle-question"></i>
            <span><strong>FAQ</strong><span>{t(locale, "main.249")}</span></span>
          </a>
        </div>
        <p class="response-note">{t(locale, "main.314")}</p>
      </aside>

      <section class="form-panel">
        <div class="section-label">{t(locale, "main.315")}</div>
        <h2>{t(locale, "supc.form.title")}</h2>
        <p>{t(locale, "fx.required")}</p>
        <form class="sales-form" id="supportForm" data-locale={locale}
          data-msg-sending={STATUS.sending}
          data-msg-success={STATUS.success}
          data-msg-error={STATUS.error}
          data-msg-fallback={STATUS.fallback}
        >
          <label class="hidden-field" aria-hidden="true">
            {t(locale, "main.411")}
            <input type="text" name="website" tabindex="-1" autocomplete="off" />
          </label>
          <div class="field-grid">
            <label>
              {t(locale, "main.412")}
              <input type="text" name="name" autocomplete="name" required />
            </label>
            <label>
              {t(locale, "main.182")}
              <input type="text" name="company" autocomplete="organization" />
            </label>
          </div>
          <div class="field-grid">
            <label>
              {t(locale, "main.413")}
              <input type="email" name="email" autocomplete="email" required />
            </label>
            <label>
              {t(locale, "supc.f.issue")}
              <select name="issueType">
                <option value="">{t(locale, "main.320")}</option>
                {ISSUE_OPTIONS.map((o) => (<option value={o.value}>{t(locale, o.labelKey)}</option>))}
              </select>
            </label>
          </div>
          <div class="field-grid">
            <label>
              {t(locale, "fx.model")}
              <input type="text" name="productModel" placeholder={t(locale, "fx.modelPh")} />
            </label>
            <label>
              {t(locale, "supc.f.serial")}
              <input type="text" name="serialNumber" />
            </label>
          </div>
          <label>
            {t(locale, "supc.f.message")}
            <textarea name="message" placeholder={t(locale, "supc.f.messagePh")} required minlength="8"></textarea>
          </label>
          {TURNSTILE_SITE_KEY && (
            <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY}></div>
          )}
          <div class="form-status" id="supportStatus" role="status" aria-live="polite"></div>
          <div class="form-footer">
            <button class="button button-primary" type="submit">{t(locale, "supc.submit")} <i class="fa-solid fa-arrow-right"></i></button>
            <p class="form-disclaimer">{t(locale, "main.323")}</p>
          </div>
        </form>
      </section>
    </section>
  </main>

  <Footer slot="footer" locale={locale} />
  {TURNSTILE_SITE_KEY && <script is:inline async defer src={TURNSTILE_SCRIPT_URL}></script>}

  <script is:inline>
    (() => {
      const navItems = Array.from(document.querySelectorAll(".nav-item"));
      const closeDelay = 520;
      const isTouchNavigation = () => window.matchMedia("(hover: none)").matches;

      const closeItem = (item) => {
        window.clearTimeout(item.closeTimer);
        item.closeTimer = window.setTimeout(() => {
          item.classList.remove("is-open");
          item.querySelectorAll(".mega-link-group.is-open").forEach((group) => group.classList.remove("is-open"));
        }, closeDelay);
      };

      const setActiveGroup = (groups, activeGroup) => {
        groups.forEach((group) => group.classList.toggle("is-open", group === activeGroup));
      };

      const openItem = (item, groups) => {
        navItems.forEach((otherItem) => {
          if (otherItem !== item) {
            window.clearTimeout(otherItem.closeTimer);
            otherItem.classList.remove("is-open");
            otherItem.querySelectorAll(".mega-link-group.is-open").forEach((group) => group.classList.remove("is-open"));
          }
        });

        window.clearTimeout(item.closeTimer);
        item.classList.add("is-open");

        if (groups.length && !groups.some((group) => group.classList.contains("is-open"))) {
          setActiveGroup(groups, groups[0]);
        }
      };

      navItems.forEach((item) => {
        const menu = item.querySelector(".mega-menu");
        if (!menu) {
          return;
        }

        const groups = Array.from(item.querySelectorAll(".mega-link-group"));
        const trigger = item.querySelector(".nav-trigger");
        trigger?.addEventListener("click", (event) => {
          if (isTouchNavigation() && !item.classList.contains("is-open")) {
            event.preventDefault();
            openItem(item, groups);
          }
        });

        item.addEventListener("pointerenter", () => openItem(item, groups));
        item.addEventListener("pointerleave", () => closeItem(item));
        menu.addEventListener("pointerenter", () => openItem(item, groups));
        menu.addEventListener("pointerleave", () => closeItem(item));
        item.addEventListener("focusin", () => openItem(item, groups));
        item.addEventListener("focusout", (event) => {
          if (!item.contains(event.relatedTarget)) {
            closeItem(item);
          }
        });

        groups.forEach((group) => {
          const groupTrigger = group.querySelector(".mega-link");
          groupTrigger?.addEventListener("click", (event) => {
            if (isTouchNavigation() && !group.classList.contains("is-open")) {
              event.preventDefault();
              openItem(item, groups);
              setActiveGroup(groups, group);
            }
          });

          group.addEventListener("pointerenter", () => {
            openItem(item, groups);
            setActiveGroup(groups, group);
          });
          group.addEventListener("focusin", () => {
            openItem(item, groups);
            setActiveGroup(groups, group);
          });

          group.querySelectorAll(".submenu a").forEach((link) => {
            link.addEventListener("pointerenter", () => {
              openItem(item, groups);
              setActiveGroup(groups, group);
            });
            link.addEventListener("focus", () => {
              openItem(item, groups);
              setActiveGroup(groups, group);
            });
            link.addEventListener("click", (event) => {
              event.stopPropagation();
            });
          });
        });
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          navItems.forEach((item) => {
            window.clearTimeout(item.closeTimer);
            item.classList.remove("is-open");
            item.querySelectorAll(".mega-link-group.is-open").forEach((group) => group.classList.remove("is-open"));
          });
        }
      });
    })();
  </script>

  <script>
    // Form logic lives in the forms layer (src/lib/forms/support-request.ts).
    import { submitSupportRequest, normalizeSupportPayload } from '../lib/forms/support-request';

    const supportForm = document.getElementById("supportForm") as HTMLFormElement | null;
    const supportStatus = document.getElementById("supportStatus");

    // Prefill from query params (e.g. ?productModel=GY-A90%20Touch).
    if (supportForm) {
      const q = new URLSearchParams(window.location.search);
      for (const field of ["productModel", "issueType"]) {
        const v = q.get(field);
        if (!v) continue;
        const el = supportForm.elements.namedItem(field) as HTMLInputElement | HTMLSelectElement | null;
        if (el) el.value = v;
      }
    }

    function setSupportStatus(message: string, type: string) {
      if (!supportStatus) return;
      supportStatus.textContent = message;
      supportStatus.className = `form-status is-visible ${type ? `is-${type}` : ""}`;
    }

    supportForm?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!supportForm.reportValidity()) return;

      const submitButton = supportForm.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      const payload = normalizeSupportPayload(new FormData(supportForm), supportForm.dataset.locale || "en");

      supportForm.classList.add("is-sending");
      if (submitButton) submitButton.disabled = true;
      setSupportStatus(supportForm.dataset.msgSending || "", "");

      const result = await submitSupportRequest(payload);
      const body = result.ok ? result.data : null;

      if (result.ok && body && body.ok) {
        supportForm.reset();
        setSupportStatus(body.message || supportForm.dataset.msgSuccess || "", "success");
      } else {
        const message =
          (!result.ok && result.error && result.error.message) ||
          (body && body.message) ||
          supportForm.dataset.msgError;
        setSupportStatus(`${message} ${supportForm.dataset.msgFallback}`, "error");
      }

      (window as any).turnstile?.reset?.();
      supportForm.classList.remove("is-sending");
      if (submitButton) submitButton.disabled = false;
    });
  </script>
</Layout>
