---
import Layout from '../layouts/Layout.astro';
import { t, localizeUrl, type Locale } from '../i18n';
import Footer from './Footer.astro';
import { canonicalUrl } from '../utils/seo';
import { createOrganizationJsonLd, breadcrumbFromHome } from '../utils/structured-data';
import { CONTACT_PRODUCT_OPTIONS } from '../data/products';
import { TURNSTILE_SITE_KEY, TURNSTILE_SCRIPT_URL } from '../config/turnstile';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const path = '/contact-sales.html';
const structuredData = [
  createOrganizationJsonLd(),
  breadcrumbFromHome(locale, [{ name: t(locale, 'fnav.contact'), url: canonicalUrl(locale, path) }]),
];
// Localized form status messages (shown after submit). Passed to the client script via
// data-* attributes on the form so the bundled module stays locale-agnostic.
const STATUS = ({
  en: {
    sending: 'Sending your inquiry...',
    success: 'Thanks. Your inquiry has been sent to the GYUTRON sales team.',
    error: 'The inquiry could not be sent right now.',
    fallback: 'Please email info@gyutron.com or use WhatsApp: +852 69509801.',
  },
  de: {
    sending: 'Ihre Anfrage wird gesendet …',
    success: 'Danke. Ihre Anfrage wurde an das GYUTRON-Vertriebsteam gesendet.',
    error: 'Die Anfrage konnte derzeit nicht gesendet werden.',
    fallback: 'Bitte schreiben Sie an info@gyutron.com oder nutzen Sie WhatsApp: +852 69509801.',
  },
  ja: {
    sending: 'お問い合わせを送信しています…',
    success: 'ありがとうございます。お問い合わせを GYUTRON 営業チームに送信しました。',
    error: '現在お問い合わせを送信できませんでした。',
    fallback: 'info@gyutron.com までメールするか、WhatsApp: +852 69509801 をご利用ください。',
  },
} as const)[locale];
---
<Layout
  locale={locale}
  path={path}
  title={t(locale, 'seo.contact-sales.title')}
  description={t(locale, 'seo.contact-sales.desc')}
  ogTitle={t(locale, 'seo.contact-sales.ogtitle')}
  ogDescription={t(locale, 'seo.contact-sales.ogdesc')}
  pageCss={["/contact-page.css", "/mobile-navigation.css"]}
  structuredData={structuredData}
>
  <main>
    <section class="contact-hero">
      <div class="container">
        <span class="eyebrow">{t(locale, "main.307")}</span>
        <h1>{t(locale, "main.308")}</h1>
        <p>{t(locale, "main.309")}</p>
      </div>
    </section>

    <section class="container contact-layout" aria-label={t(locale, "main.310")}>
      <aside class="info-panel">
        <div class="section-label">{t(locale, "main.311")}</div>
        <h2>{t(locale, "main.312")}</h2>
        <p>{t(locale, "main.313")}</p>
        <div class="contact-methods">
          <a class="contact-method" href="mailto:info@gyutron.com">
            <i class="fa-solid fa-envelope"></i>
            <span><strong>{t(locale, "main.410")}</strong><span>info@gyutron.com</span></span>
          </a>
          <a class="contact-method" href="https://wa.me/85269509801">
            <i class="fa-brands fa-whatsapp"></i>
            <span><strong>WhatsApp</strong><span>+852 69509801</span></span>
          </a>
          <a class="contact-method" href="https://www.linkedin.com/company/gyutron/" target="_blank" rel="noopener">
            <i class="fa-brands fa-linkedin-in"></i>
            <span><strong>LinkedIn</strong><span>linkedin.com/company/gyutron</span></span>
          </a>
        </div>
        <p class="response-note">{t(locale, "main.314")}</p>
      </aside>

      <section class="form-panel">
        <div class="section-label">{t(locale, "main.315")}</div>
        <h2>{t(locale, "main.316")}</h2>
        <p>{t(locale, "main.317")}</p>
        <form class="sales-form" id="salesInquiryForm"
          data-msg-sending={STATUS.sending}
          data-msg-success={STATUS.success}
          data-msg-error={STATUS.error}
          data-msg-fallback={STATUS.fallback}
        >
          <label class="hidden-field" aria-hidden="true">
            {t(locale, "main.411")}
            <input type="text" name="website" tabindex="-1" autocomplete="off" />
          </label>
          <div class="field-grid">
            <label>
              {t(locale, "main.412")}
              <input type="text" name="fullName" autocomplete="name" required />
            </label>
            <label>
              {t(locale, "main.182")}
              <input type="text" name="company" autocomplete="organization" required />
            </label>
          </div>
          <div class="field-grid">
            <label>
              {t(locale, "main.413")}
              <input type="email" name="workEmail" autocomplete="email" required />
            </label>
            <label>
              {t(locale, "main.318")}
              <input type="tel" name="phone" autocomplete="tel" />
            </label>
          </div>
          <div class="field-grid">
            <label>
              {t(locale, "main.319")}
              <input type="text" name="country" autocomplete="country-name" />
            </label>
            <label>
              {t(locale, "main.414")}
              <select name="productInterest" required>
                <option value="">{t(locale, "main.320")}</option>
                {CONTACT_PRODUCT_OPTIONS.map((o) => (<option>{t(locale, o.labelKey)}</option>))}
                <option>{t(locale, "main.415")}</option>
              </select>
            </label>
          </div>
          <label>
            {t(locale, "main.416")}
            <textarea name="projectDetails" placeholder={t(locale, "main.321")} required></textarea>
          </label>
          {TURNSTILE_SITE_KEY && (
            <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY}></div>
          )}
          <div class="form-status" id="salesInquiryStatus" role="status" aria-live="polite"></div>
          <div class="form-footer">
            <button class="button button-primary" type="submit">{t(locale, "main.322")} <i class="fa-solid fa-arrow-right"></i></button>
            <p class="form-disclaimer">{t(locale, "main.323")}</p>
          </div>
        </form>
      </section>
    </section>

    <section class="process">
      <div class="container process-grid" aria-label="Sales process">
        <article class="process-card">
          <span>{t(locale, "main.417")}</span>
          <h3>{t(locale, "main.324")}</h3>
          <p>{t(locale, "main.325")}</p>
        </article>
        <article class="process-card">
          <span>{t(locale, "main.418")}</span>
          <h3>{t(locale, "main.326")}</h3>
          <p>{t(locale, "main.327")}</p>
        </article>
        <article class="process-card">
          <span>{t(locale, "main.328")}</span>
          <h3>{t(locale, "main.329")}</h3>
          <p>{t(locale, "main.330")}</p>
        </article>
      </div>
    </section>
  </main>

  <Footer slot="footer" locale={locale} />
  {TURNSTILE_SITE_KEY && <script is:inline async defer src={TURNSTILE_SCRIPT_URL}></script>}

  <script is:inline>
    (() => {
      const navItems = Array.from(document.querySelectorAll(".nav-item"));
      const closeDelay = 520;
      const isTouchNavigation = () => window.matchMedia("(hover: none)").matches;

      const closeItem = (item) => {
        window.clearTimeout(item.closeTimer);
        item.closeTimer = window.setTimeout(() => {
          item.classList.remove("is-open");
          item.querySelectorAll(".mega-link-group.is-open").forEach((group) => group.classList.remove("is-open"));
        }, closeDelay);
      };

      const setActiveGroup = (groups, activeGroup) => {
        groups.forEach((group) => group.classList.toggle("is-open", group === activeGroup));
      };

      const openItem = (item, groups) => {
        navItems.forEach((otherItem) => {
          if (otherItem !== item) {
            window.clearTimeout(otherItem.closeTimer);
            otherItem.classList.remove("is-open");
            otherItem.querySelectorAll(".mega-link-group.is-open").forEach((group) => group.classList.remove("is-open"));
          }
        });

        window.clearTimeout(item.closeTimer);
        item.classList.add("is-open");

        if (groups.length && !groups.some((group) => group.classList.contains("is-open"))) {
          setActiveGroup(groups, groups[0]);
        }
      };

      navItems.forEach((item) => {
        const menu = item.querySelector(".mega-menu");
        if (!menu) {
          return;
        }

        const groups = Array.from(item.querySelectorAll(".mega-link-group"));
        const trigger = item.querySelector(".nav-trigger");
        trigger?.addEventListener("click", (event) => {
          if (isTouchNavigation() && !item.classList.contains("is-open")) {
            event.preventDefault();
            openItem(item, groups);
          }
        });

        item.addEventListener("pointerenter", () => openItem(item, groups));
        item.addEventListener("pointerleave", () => closeItem(item));
        menu.addEventListener("pointerenter", () => openItem(item, groups));
        menu.addEventListener("pointerleave", () => closeItem(item));
        item.addEventListener("focusin", () => openItem(item, groups));
        item.addEventListener("focusout", (event) => {
          if (!item.contains(event.relatedTarget)) {
            closeItem(item);
          }
        });

        groups.forEach((group) => {
          const groupTrigger = group.querySelector(".mega-link");
          groupTrigger?.addEventListener("click", (event) => {
            if (isTouchNavigation() && !group.classList.contains("is-open")) {
              event.preventDefault();
              openItem(item, groups);
              setActiveGroup(groups, group);
            }
          });

          group.addEventListener("pointerenter", () => {
            openItem(item, groups);
            setActiveGroup(groups, group);
          });
          group.addEventListener("focusin", () => {
            openItem(item, groups);
            setActiveGroup(groups, group);
          });

          group.querySelectorAll(".submenu a").forEach((link) => {
            link.addEventListener("pointerenter", () => {
              openItem(item, groups);
              setActiveGroup(groups, group);
            });
            link.addEventListener("focus", () => {
              openItem(item, groups);
              setActiveGroup(groups, group);
            });
            link.addEventListener("click", (event) => {
              event.stopPropagation();
            });
          });
        });
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          navItems.forEach((item) => {
            window.clearTimeout(item.closeTimer);
            item.classList.remove("is-open");
            item.querySelectorAll(".mega-link-group.is-open").forEach((group) => group.classList.remove("is-open"));
          });
        }
      });
    })();
  </script>

  <script>
    // Form logic lives in the forms layer (src/lib/forms/contact.ts) — the page only
    // collects fields, calls submitContactForm(), and renders the status. Behavior is
    // unchanged: HTML5 validation, same /api/contact endpoint, same status messages.
    import { submitContactForm, normalizeContactPayload } from '../lib/forms/contact';

    const salesForm = document.getElementById("salesInquiryForm");
    const salesStatus = document.getElementById("salesInquiryStatus");

    function setSalesStatus(message, type) {
      if (!salesStatus) return;
      salesStatus.textContent = message;
      salesStatus.className = `form-status is-visible ${type ? `is-${type}` : ""}`;
    }

    salesForm?.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (!salesForm.reportValidity()) {
        return;
      }

      const submitButton = salesForm.querySelector('button[type="submit"]');
      const payload = normalizeContactPayload(new FormData(salesForm));

      salesForm.classList.add("is-sending");
      if (submitButton) submitButton.disabled = true;
      setSalesStatus(salesForm.dataset.msgSending, "");

      const result = await submitContactForm(payload);
      const body = result.ok ? result.data : null;

      if (result.ok && body && body.ok) {
        salesForm.reset();
        setSalesStatus(body.message || salesForm.dataset.msgSuccess, "success");
      } else {
        const message =
          (!result.ok && result.error && result.error.message) ||
          (body && body.message) ||
          salesForm.dataset.msgError;
        setSalesStatus(`${message} ${salesForm.dataset.msgFallback}`, "error");
      }

      (window as any).turnstile?.reset?.();
      salesForm.classList.remove("is-sending");
      if (submitButton) submitButton.disabled = false;
    });
  </script>
</Layout>
