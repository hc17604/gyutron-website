---
import { t, localizeUrl, type Locale } from '../i18n';
import LangSwitch from './LangSwitch.astro';
import HeaderNav from './navigation/HeaderNav.astro';
interface Props { locale: Locale; path: string; }
const { locale, path } = Astro.props;
// Localized chrome strings for the nav search (UI chrome, not page content).
const SEARCH_I18N: Record<Locale, { label: string; placeholder: string; close: string; noresults: string }> = {
  en: { label: 'Search', placeholder: 'Search products, solutions, support…', close: 'Close search', noresults: 'No results for' },
  de: { label: 'Suche', placeholder: 'Produkte, Lösungen, Support suchen…', close: 'Suche schließen', noresults: 'Keine Ergebnisse für' },
  ja: { label: '検索', placeholder: '製品・ソリューション・サポートを検索…', close: '検索を閉じる', noresults: '該当する結果がありません:' },
};
const si = SEARCH_I18N[locale];
---
    <div class="top-strip">
        <div class="container">
            <span><i class="fa-solid fa-location-crosshairs"></i> {t(locale, "main.001")}</span>
            <div class="top-strip-links">
                <a href="https://shop.gyutron.com">{t(locale, "main.002")}</a>
                <a href={localizeUrl(locale, "/index.html#contact")}>{t(locale, "main.003")}</a>
            </div>
        </div>
    </div>

    <header class="site-header">
        <div class="container">
            <a class="brand" href={localizeUrl(locale, "/index.html")} aria-label="GYUTRON home">
                <img class="brand-logo" src="/gyutron-logo-purple.png" alt="GYUTRON">
            </a>
            <LangSwitch variant="mobile" locale={locale} path={path} />
            <HeaderNav locale={locale} />
            <div class="header-actions">
                <div class="nav-search" data-locale={locale} data-noresults={si.noresults}>
                    <button type="button" class="nav-search-toggle" aria-label={si.label} aria-expanded="false" aria-haspopup="true">
                        <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
                    </button>
                    <div class="nav-search-dropdown" hidden>
                        <div class="nav-search-bar">
                            <i class="fa-solid fa-magnifying-glass nav-search-bar-icon" aria-hidden="true"></i>
                            <input type="search" class="nav-search-input" placeholder={si.placeholder} aria-label={si.label} autocomplete="off" enterkeyhint="search" />
                            <button type="button" class="nav-search-close" aria-label={si.close}><i class="fa-solid fa-xmark" aria-hidden="true"></i></button>
                        </div>
                        <div class="nav-search-results" role="listbox" aria-label={si.label}></div>
                    </div>
                </div>
                <LangSwitch variant="desktop" locale={locale} path={path} />
                <a class="button button-primary" href={localizeUrl(locale, "/contact-sales.html")}><span class="cta-label-full">{t(locale, "main.256")}</span><span class="cta-label-short">{t(locale, "main.257")}</span> <i class="fa-solid fa-arrow-right"></i></a>
            </div>
        </div>
    </header>
    <script is:inline>
      (() => {
        const links = Array.from(document.querySelectorAll(".mega-links"));
        links.forEach((panel) => {
          const menu = panel.closest(".mega-menu");
          if (!menu || menu.querySelector(".mega-scrollbar")) return;

          const bar = document.createElement("div");
          const thumb = document.createElement("span");
          bar.className = "mega-scrollbar";
          thumb.className = "mega-scrollbar-thumb";
          bar.setAttribute("aria-hidden", "true");
          bar.appendChild(thumb);
          menu.appendChild(bar);

          let hideTimer = 0;
          let frame = 0;
          let dragging = false;
          let startY = 0;
          let startScrollTop = 0;
          const canScroll = () => panel.scrollHeight > panel.clientHeight + 2;

          const updateScrollbar = () => {
            frame = 0;
            const needed = canScroll();
            bar.classList.toggle("is-needed", needed);
            if (!needed) {
              bar.classList.remove("is-visible");
              return;
            }

            const inset = 10;
            const trackHeight = Math.max(48, panel.clientHeight - inset * 2);
            const thumbHeight = Math.max(42, Math.round(trackHeight * (panel.clientHeight / panel.scrollHeight)));
            const maxScroll = panel.scrollHeight - panel.clientHeight;
            const maxThumbTop = Math.max(0, trackHeight - thumbHeight);
            const thumbTop = maxScroll > 0 ? Math.round((panel.scrollTop / maxScroll) * maxThumbTop) : 0;

            bar.style.setProperty("--mega-scrollbar-left", `${panel.offsetLeft + panel.clientWidth - 11}px`);
            bar.style.setProperty("--mega-scrollbar-top", `${panel.offsetTop + inset}px`);
            bar.style.setProperty("--mega-scrollbar-height", `${trackHeight}px`);
            thumb.style.height = `${thumbHeight}px`;
            thumb.style.transform = `translate3d(0, ${thumbTop}px, 0)`;
          };

          const requestUpdate = () => {
            if (frame) return;
            frame = window.requestAnimationFrame(updateScrollbar);
          };

          const revealScrollbar = () => {
            requestUpdate();
            if (!canScroll()) return;
            bar.classList.add("is-visible");
            window.clearTimeout(hideTimer);
            if (!dragging) {
              hideTimer = window.setTimeout(() => bar.classList.remove("is-visible"), 950);
            }
          };

          const endDrag = (event) => {
            if (!dragging) return;
            dragging = false;
            thumb.releasePointerCapture?.(event.pointerId);
            window.clearTimeout(hideTimer);
            hideTimer = window.setTimeout(() => bar.classList.remove("is-visible"), 650);
          };

          panel.addEventListener("scroll", revealScrollbar, { passive: true });
          panel.addEventListener("wheel", revealScrollbar, { passive: true });
          panel.addEventListener("touchmove", revealScrollbar, { passive: true });
          panel.addEventListener("pointerleave", () => {
            window.clearTimeout(hideTimer);
            if (!dragging) {
              hideTimer = window.setTimeout(() => bar.classList.remove("is-visible"), 420);
            }
          });
          menu.addEventListener("mouseenter", requestUpdate, { passive: true });
          window.addEventListener("resize", requestUpdate, { passive: true });

          bar.addEventListener("pointerdown", (event) => {
            if (!canScroll()) return;
            const rect = bar.getBoundingClientRect();
            const thumbHeight = thumb.offsetHeight || 42;
            const targetTop = event.clientY - rect.top - thumbHeight / 2;
            const scrollRatio = Math.max(0, Math.min(1, targetTop / Math.max(1, rect.height - thumbHeight)));
            panel.scrollTop = scrollRatio * (panel.scrollHeight - panel.clientHeight);
            revealScrollbar();
          });

          thumb.addEventListener("pointerdown", (event) => {
            if (!canScroll()) return;
            dragging = true;
            startY = event.clientY;
            startScrollTop = panel.scrollTop;
            thumb.setPointerCapture?.(event.pointerId);
            revealScrollbar();
            event.preventDefault();
          });
          thumb.addEventListener("pointermove", (event) => {
            if (!dragging) return;
            const trackHeight = Math.max(48, panel.clientHeight - 20);
            const thumbHeight = thumb.offsetHeight || 42;
            const scrollRange = panel.scrollHeight - panel.clientHeight;
            const dragRange = Math.max(1, trackHeight - thumbHeight);
            panel.scrollTop = startScrollTop + ((event.clientY - startY) / dragRange) * scrollRange;
          });
          thumb.addEventListener("pointerup", endDrag);
          thumb.addEventListener("pointercancel", endDrag);

          requestUpdate();
        });
      })();

      (() => {
        // mega-menu active submenu (JS-driven): default = first group on open, switch on hover,
        // stays sticky while the pointer is inside the active group's submenu (a child of the group).
        // The active group is deliberately NOT cleared on leave: the submenu stays put while the menu
        // closes, so the .mega-menu::after overview image never flashes through. Re-opening resets to
        // the first group. Fixes: blank panel on tab-hover, revert-to-first, and the leave flash.
        Array.prototype.forEach.call(document.querySelectorAll(".nav-item"), (item) => {
          const menu = item.querySelector(".mega-menu");
          if (!menu) return;
          const groups = Array.prototype.slice.call(menu.querySelectorAll(".mega-link-group"));
          if (!groups.length) return;
          const setActive = (g) => groups.forEach((x) => x.classList.toggle("is-open", x === g));
          item.addEventListener("pointerenter", () => setActive(groups[0]));
          item.addEventListener("focusin", (e) => {
            const g = e.target.closest && e.target.closest(".mega-link-group");
            setActive(g || groups[0]);
          });
          groups.forEach((g) => g.addEventListener("pointerenter", () => setActive(g)));
        });
      })();

      (() => {
        const closeMenus = () => {
          document.body.classList.add("nav-is-navigating");
          document.querySelectorAll(".mega-link-group.is-open").forEach((group) => group.classList.remove("is-open"));
          document.querySelectorAll(".nav-item.is-open").forEach((item) => item.classList.remove("is-open"));
          if (document.activeElement && document.activeElement instanceof HTMLElement) {
            document.activeElement.blur();
          }
        };

        document.querySelectorAll(".site-header a[href], .top-strip a[href]").forEach((link) => {
          link.addEventListener("click", (event) => {
            const anchor = event.currentTarget;
            const href = anchor.getAttribute("href") || "";
            if (anchor.target === "_blank" || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
            closeMenus();
            if (href.startsWith("#") || href.includes("#")) {
              window.setTimeout(() => document.body.classList.remove("nav-is-navigating"), 420);
            }
          }, { capture: true });
        });

        window.addEventListener("pageshow", () => document.body.classList.remove("nav-is-navigating"));
      })();
    </script>
