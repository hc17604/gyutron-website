---
/** Presentational section heading: optional eyebrow + title + optional subtitle. */
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}
const { eyebrow, title, subtitle, align = 'left' } = Astro.props;
---
<header class:list={['section-title', `section-title--${align}`]}>
  {eyebrow && <p class="section-title__eyebrow">{eyebrow}</p>}
  <h2 class="section-title__heading">{title}</h2>
  {subtitle && <p class="section-title__subtitle">{subtitle}</p>}
</header>
