---
import Layout from '../layouts/Layout.astro';
import { t, localizeUrl, type Locale } from '../i18n';
import Footer from './Footer.astro';
import { canonicalUrl } from '../utils/seo';
import { createOrganizationJsonLd, breadcrumbFromHome } from '../utils/structured-data';
import { TURNSTILE_SITE_KEY, TURNSTILE_SCRIPT_URL } from '../config/turnstile';
import downloads from '../data/downloads.json';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const path = '/resources/download-request.html';
const structuredData = [
  createOrganizationJsonLd(),
  breadcrumbFromHome(locale, [{ name: t(locale, 'dlr.title'), url: canonicalUrl(locale, path) }]),
];
// Document options from the resource-center manifest (single source of truth shared
// with the worker). Value = stable manifest id; titles stay English (technical docs).
const FILE_OPTIONS = (downloads.files || []).map((f: any) => ({ id: f.id, title: f.title }));
const STATUS = ({
  en: {
    sending: 'Sending your request...',
    success: 'Thanks. Your download request has been received — we will email you the document.',
    error: 'The request could not be sent right now.',
    fallback: 'Please email info@gyutron.com or use WhatsApp: +852 69509801.',
  },
  de: {
    sending: 'Ihre Anfrage wird gesendet …',
    success: 'Danke. Ihre Download-Anfrage ist eingegangen – wir senden Ihnen das Dokument per E-Mail.',
    error: 'Die Anfrage konnte derzeit nicht gesendet werden.',
    fallback: 'Bitte schreiben Sie an info@gyutron.com oder nutzen Sie WhatsApp: +852 69509801.',
  },
  ja: {
    sending: '申請を送信しています…',
    success: 'ありがとうございます。資料のご請求を受け付けました。メールにてお送りします。',
    error: '現在リクエストを送信できませんでした。',
    fallback: 'info@gyutron.com までメールするか、WhatsApp: +852 69509801 をご利用ください。',
  },
} as const)[locale];
---
<Layout
  locale={locale}
  path={path}
  title={t(locale, 'seo.download-request.title')}
  description={t(locale, 'seo.download-request.desc')}
  ogTitle={t(locale, 'seo.download-request.ogtitle')}
  ogDescription={t(locale, 'seo.download-request.ogdesc')}
  pageCss={["/contact-page.css", "/mobile-navigation.css"]}
  structuredData={structuredData}
>
  <main>
    <section class="contact-hero">
      <div class="container">
        <span class="eyebrow">{t(locale, "dlr.eyebrow")}</span>
        <h1>{t(locale, "dlr.title")}</h1>
        <p>{t(locale, "dlr.sub")}</p>
      </div>
    </section>

    <section class="container contact-layout" aria-label={t(locale, "dlr.title")}>
      <aside class="info-panel">
        <div class="section-label">{t(locale, "dlr.eyebrow")}</div>
        <h2>{t(locale, "dlr.info.title")}</h2>
        <p>{t(locale, "dlr.info.text")}</p>
        <div class="contact-methods">
          <a class="contact-method" href="mailto:info@gyutron.com">
            <i class="fa-solid fa-envelope"></i>
            <span><strong>{t(locale, "main.410")}</strong><span>info@gyutron.com</span></span>
          </a>
          <a class="contact-method" href={localizeUrl(locale, '/support/contact.html')}>
            <i class="fa-solid fa-headset"></i>
            <span><strong>{t(locale, "supc.title")}</strong><span>{t(locale, "main.255")}</span></span>
          </a>
        </div>
        <p class="response-note">{t(locale, "main.314")}</p>
      </aside>

      <section class="form-panel">
        <div class="section-label">{t(locale, "main.315")}</div>
        <h2>{t(locale, "dlr.form.title")}</h2>
        <p>{t(locale, "fx.required")}</p>
        <form class="sales-form" id="downloadForm" data-locale={locale}
          data-msg-sending={STATUS.sending}
          data-msg-success={STATUS.success}
          data-msg-error={STATUS.error}
          data-msg-fallback={STATUS.fallback}
          data-msg-ready={t(locale, "dlr.ready")}
        >
          <label class="hidden-field" aria-hidden="true">
            {t(locale, "main.411")}
            <input type="text" name="website" tabindex="-1" autocomplete="off" />
          </label>
          <div class="field-grid">
            <label>
              {t(locale, "main.412")}
              <input type="text" name="name" autocomplete="name" required />
            </label>
            <label>
              {t(locale, "main.182")}
              <input type="text" name="company" autocomplete="organization" />
            </label>
          </div>
          <div class="field-grid">
            <label>
              {t(locale, "main.413")}
              <input type="email" name="email" autocomplete="email" required />
            </label>
            <label>
              {t(locale, "main.319")}
              <input type="text" name="country" autocomplete="country-name" />
            </label>
          </div>
          <label>
            {t(locale, "dlr.f.file")}
            <select name="requestedFile" required>
              <option value="">{t(locale, "main.320")}</option>
              {FILE_OPTIONS.map((o) => (<option value={o.id}>{o.title}</option>))}
              <option value="other">{t(locale, "dlr.f.other")}</option>
            </select>
          </label>
          <label id="downloadOtherWrap" hidden>
            {t(locale, "dlr.f.otherFile")}
            <input type="text" name="requestedFileOther" placeholder={t(locale, "dlr.f.otherPh")} />
          </label>
          <label>
            {t(locale, "fx.model")}
            <input type="text" name="productModel" placeholder={t(locale, "fx.modelPh")} />
          </label>
          {TURNSTILE_SITE_KEY && (
            <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY}></div>
          )}
          <div class="form-status" id="downloadStatus" role="status" aria-live="polite"></div>
          <div class="form-footer">
            <button class="button button-primary" type="submit">{t(locale, "dlr.submit")} <i class="fa-solid fa-arrow-right"></i></button>
            <p class="form-disclaimer">{t(locale, "main.323")}</p>
          </div>
        </form>
      </section>
    </section>
  </main>

  <Footer slot="footer" locale={locale} />
  {TURNSTILE_SITE_KEY && <script is:inline async defer src={TURNSTILE_SCRIPT_URL}></script>}

  <script is:inline>
    (() => {
      const navItems = Array.from(document.querySelectorAll(".nav-item"));
      const closeDelay = 520;
      const isTouchNavigation = () => window.matchMedia("(hover: none)").matches;

      const closeItem = (item) => {
        window.clearTimeout(item.closeTimer);
        item.closeTimer = window.setTimeout(() => {
          item.classList.remove("is-open");
          item.querySelectorAll(".mega-link-group.is-open").forEach((group) => group.classList.remove("is-open"));
        }, closeDelay);
      };

      const setActiveGroup = (groups, activeGroup) => {
        groups.forEach((group) => group.classList.toggle("is-open", group === activeGroup));
      };

      const openItem = (item, groups) => {
        navItems.forEach((otherItem) => {
          if (otherItem !== item) {
            window.clearTimeout(otherItem.closeTimer);
            otherItem.classList.remove("is-open");
            otherItem.querySelectorAll(".mega-link-group.is-open").forEach((group) => group.classList.remove("is-open"));
          }
        });

        window.clearTimeout(item.closeTimer);
        item.classList.add("is-open");

        if (groups.length && !groups.some((group) => group.classList.contains("is-open"))) {
          setActiveGroup(groups, groups[0]);
        }
      };

      navItems.forEach((item) => {
        const menu = item.querySelector(".mega-menu");
        if (!menu) {
          return;
        }

        const groups = Array.from(item.querySelectorAll(".mega-link-group"));
        const trigger = item.querySelector(".nav-trigger");
        trigger?.addEventListener("click", (event) => {
          if (isTouchNavigation() && !item.classList.contains("is-open")) {
            event.preventDefault();
            openItem(item, groups);
          }
        });

        item.addEventListener("pointerenter", () => openItem(item, groups));
        item.addEventListener("pointerleave", () => closeItem(item));
        menu.addEventListener("pointerenter", () => openItem(item, groups));
        menu.addEventListener("pointerleave", () => closeItem(item));
        item.addEventListener("focusin", () => openItem(item, groups));
        item.addEventListener("focusout", (event) => {
          if (!item.contains(event.relatedTarget)) {
            closeItem(item);
          }
        });

        groups.forEach((group) => {
          const groupTrigger = group.querySelector(".mega-link");
          groupTrigger?.addEventListener("click", (event) => {
            if (isTouchNavigation() && !group.classList.contains("is-open")) {
              event.preventDefault();
              openItem(item, groups);
              setActiveGroup(groups, group);
            }
          });

          group.addEventListener("pointerenter", () => {
            openItem(item, groups);
            setActiveGroup(groups, group);
          });
          group.addEventListener("focusin", () => {
            openItem(item, groups);
            setActiveGroup(groups, group);
          });

          group.querySelectorAll(".submenu a").forEach((link) => {
            link.addEventListener("pointerenter", () => {
              openItem(item, groups);
              setActiveGroup(groups, group);
            });
            link.addEventListener("focus", () => {
              openItem(item, groups);
              setActiveGroup(groups, group);
            });
            link.addEventListener("click", (event) => {
              event.stopPropagation();
            });
          });
        });
      });

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          navItems.forEach((item) => {
            window.clearTimeout(item.closeTimer);
            item.classList.remove("is-open");
            item.querySelectorAll(".mega-link-group.is-open").forEach((group) => group.classList.remove("is-open"));
          });
        }
      });
    })();
  </script>

  <script>
    // Form logic lives in the forms layer (src/lib/forms/download-request.ts). When the
    // worker can deliver the file immediately (public/gated + R2 active) it returns
    // download.url — rendered as a link in the status area.
    import { submitDownloadRequest, normalizeDownloadRequestPayload } from '../lib/forms/download-request';

    const dlForm = document.getElementById("downloadForm") as HTMLFormElement | null;
    const dlStatus = document.getElementById("downloadStatus");
    const otherWrap = document.getElementById("downloadOtherWrap");
    const fileSelect = dlForm?.elements.namedItem("requestedFile") as HTMLSelectElement | null;
    const otherInput = dlForm?.elements.namedItem("requestedFileOther") as HTMLInputElement | null;

    // Prefill from query params (e.g. ?requestedFile=ds-gy-a90-touch).
    if (dlForm && fileSelect) {
      const q = new URLSearchParams(window.location.search);
      const v = q.get("requestedFile");
      if (v && [...fileSelect.options].some((o) => o.value === v)) fileSelect.value = v;
    }

    // "Other" reveals the free-text field (required while visible).
    fileSelect?.addEventListener("change", () => {
      const isOther = fileSelect.value === "other";
      if (otherWrap) otherWrap.hidden = !isOther;
      if (otherInput) {
        otherInput.required = isOther;
        if (!isOther) otherInput.value = "";
      }
    });

    function setDlStatus(message: string, type: string) {
      if (!dlStatus) return;
      dlStatus.textContent = message;
      dlStatus.className = `form-status is-visible ${type ? `is-${type}` : ""}`;
    }

    dlForm?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!dlForm.reportValidity()) return;

      const submitButton = dlForm.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      const payload = normalizeDownloadRequestPayload(new FormData(dlForm), dlForm.dataset.locale || "en");

      dlForm.classList.add("is-sending");
      if (submitButton) submitButton.disabled = true;
      setDlStatus(dlForm.dataset.msgSending || "", "");

      const result = await submitDownloadRequest(payload);
      const body = result.ok ? result.data : null;

      if (result.ok && body && body.ok) {
        dlForm.reset();
        if (otherWrap) otherWrap.hidden = true;
        if (body.download && body.download.status === "ready" && body.download.url) {
          // Immediate delivery — show the link (DOM-built; no innerHTML).
          setDlStatus(`${dlForm.dataset.msgReady || ""} `, "success");
          const a = document.createElement("a");
          a.href = body.download.url;
          a.textContent = body.download.url.split("/").pop() || "download";
          a.rel = "noopener";
          dlStatus?.appendChild(a);
        } else {
          setDlStatus(body.message || dlForm.dataset.msgSuccess || "", "success");
        }
      } else {
        const message =
          (!result.ok && result.error && result.error.message) ||
          (body && body.message) ||
          dlForm.dataset.msgError;
        setDlStatus(`${message} ${dlForm.dataset.msgFallback}`, "error");
      }

      (window as any).turnstile?.reset?.();
      dlForm.classList.remove("is-sending");
      if (submitButton) submitButton.disabled = false;
    });
  </script>
</Layout>
