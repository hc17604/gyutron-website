---
/**
 * Unified SEO <head> block — the single source for per-page SEO meta. Adopted by
 * `Layout.astro`. With only the required props it emits the same title/description/
 * canonical/hreflang/OG tags the layout used before, PLUS og:image, Twitter Card, a robots
 * directive, and Organization JSON-LD. Every field is overridable per page. See docs/SEO.md.
 */
import { htmlLang, ogLocale, locales, type Locale } from '../../i18n';
import { SITE_NAME } from '../../config/site';
import {
  DEFAULT_OG_IMAGE,
  DEFAULT_OG_TYPE,
  TWITTER_CARD,
  TWITTER_HANDLE,
  DEFAULT_ROBOTS,
  ORGANIZATION,
} from '../../config/seo';
import { absoluteUrl, canonicalUrl } from '../../utils/seo';

interface Props {
  locale: Locale;
  /** Canonical page path, no locale prefix, e.g. '/barcode-scanners.html'. */
  path: string;
  title: string;
  description: string;
  /** Override the computed canonical URL. */
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: string;
  twitterCard?: string;
  /** When true, emits robots "noindex, follow". */
  noindex?: boolean;
  /** Explicit robots directive (ignored when noindex is true). */
  robots?: string;
  /** Replace the default Organization JSON-LD (object or array). Pass null to omit. */
  structuredData?: unknown;
}
const {
  locale,
  path,
  title,
  description,
  canonical = canonicalUrl(locale, path),
  ogTitle,
  ogDescription,
  ogImage = DEFAULT_OG_IMAGE,
  ogType = DEFAULT_OG_TYPE,
  twitterCard = TWITTER_CARD,
  noindex = false,
  robots,
  structuredData = ORGANIZATION,
} = Astro.props;
const robotsContent = noindex ? 'noindex, follow' : (robots ?? DEFAULT_ROBOTS);
// Normalize to a list so a page can emit several JSON-LD nodes (Organization + Breadcrumb +
// CollectionPage). One <script> per node. The default (Organization) emits a single script,
// byte-identical to before.
const jsonLdNodes = structuredData == null ? [] : Array.isArray(structuredData) ? structuredData : [structuredData];
---
<title>{title}</title>
<meta name="description" content={description} />
<meta name="robots" content={robotsContent} />
<link rel="canonical" href={canonical} />
{locales.map((l) => (
  <link rel="alternate" hreflang={htmlLang[l]} href={canonicalUrl(l, path)} />
))}
<link rel="alternate" hreflang="x-default" href={absoluteUrl(path)} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content={ogLocale[locale]} />
<meta property="og:title" content={ogTitle ?? title} />
<meta property="og:description" content={ogDescription ?? description} />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:image" content={ogImage} />
<meta name="twitter:card" content={twitterCard} />
{TWITTER_HANDLE !== '' && <meta name="twitter:site" content={TWITTER_HANDLE} />}
<meta name="twitter:title" content={ogTitle ?? title} />
<meta name="twitter:description" content={ogDescription ?? description} />
<meta name="twitter:image" content={ogImage} />
{jsonLdNodes.map((node) => <script type="application/ld+json" set:html={JSON.stringify(node)} />)}
