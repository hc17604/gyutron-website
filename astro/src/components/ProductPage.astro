---
import Layout from '../layouts/Layout.astro';
import Footer from './Footer.astro';
import { t, localizeUrl, type Locale } from '../i18n';
import { productSummary } from '../lib/productText';
import { specLabel, specVal, tagText } from '../lib/productI18n';
import { canonicalUrl } from '../utils/seo';
import { createOrganizationJsonLd, breadcrumbFromHome, createCollectionPageJsonLd } from '../utils/structured-data';
import { getCatalog, getCategoryGroups } from '../data/products';

interface Props { locale: Locale; category: string; }
const { locale, category } = Astro.props;

const PRODUCTS: any = getCatalog(locale);
const GROUPS: any = getCategoryGroups(locale);
const cat: any = PRODUCTS[category];
const path = `/${category}.html`;
const navOrder: string[] = GROUPS[cat.navGroup || 'rugged-pda'] || [];
const canonical = canonicalUrl(locale, path);
const structuredData = [
  createOrganizationJsonLd(),
  breadcrumbFromHome(locale, [{ name: cat.title, url: canonical }]),
  createCollectionPageJsonLd({
    name: cat.title,
    description: cat.intro,
    url: canonical,
    products: (cat.products || []).map((p: any) => ({ name: p.name, description: p.summary, image: p.image, category: cat.title })),
  }),
];
---
<Layout
  locale={locale}
  path={path}
  title={t(locale, `seo.${category}.title`)}
  description={t(locale, `seo.${category}.desc`)}
  bodyClass={`product-page cat-${category}`}
  pageCss={["/product-page.css", "/mobile-navigation.css"]}
  structuredData={structuredData}
>
  <main>
    <section class="product-hero" style={cat.heroImage ? `--hero-image: url('/${cat.heroImage}')` : undefined}><div class="container"><div class="product-hero-grid">
      <div>
        <span class="eyebrow">{cat.eyebrow}</span>
        <h1>{cat.title}</h1>
        <p>{cat.intro}</p>
      </div>
      <aside class="hero-panel">
        <span>{locale === 'ja' ? '製品ラインアップ' : 'Portfolio'}</span>
        <p>{cat.panelText}</p>
      </aside>
    </div></div></section>

    <nav class="category-nav"><div class="container">
      {navOrder.map((key) => (
        <a class={key === category ? 'is-active' : ''} href={localizeUrl(locale, `/${key}.html`)}>{PRODUCTS[key]?.navLabel}</a>
      ))}
    </div></nav>

    <section class="section"><div class="container">
      <h2 class="sr-only">{cat.sectionTitle || cat.title}</h2>
      <div class="product-grid">
        {cat.products.map((product: any) => (
          <article class="product-card">
            <div class="product-art">{product.image && <img src={`/${product.image}`} alt={product.name} loading="lazy" />}</div>
            <div class="product-body">
              <div class="product-kicker">{product.type}</div>
              <h3>{product.name}</h3>
              <p>{productSummary(locale, product, cat)}</p>
              <dl class="spec-list">
                {Object.entries(product.specs).map(([label, value]) => (<div><dt>{specLabel(locale, label)}</dt><dd>{specVal(locale, value as string)}</dd></div>))}
              </dl>
              <div class="product-tags">{(product.tags || []).map((tag: string) => (<span>{tagText(locale, tag)}</span>))}</div>
              <div class="product-actions">
                <a href={localizeUrl(locale, '/contact-sales.html')}>
                  <span class="product-action-full">{t(locale, 'main.256')}</span>
                  <span class="product-action-short">{t(locale, 'pp.card.ctaShort')}</span>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div></section>

    <section class="compare-band"><div class="container">
      <span class="eyebrow">{t(locale, 'main.259')}</span>
      <h2>{t(locale, 'main.260')}</h2>
      <div class="compare-scroll"><table class="compare-table">
        <thead><tr>
          <th>{t(locale, 'pp.compare.model')}</th>
          <th>{t(locale, 'pp.compare.type')}</th>
          <th>{t(locale, 'pp.compare.capability')}</th>
          <th>{t(locale, 'pp.compare.rugged')}</th>
        </tr></thead>
        <tbody>
          {cat.products.map((p: any) => {
            const s = p.specs || {};
            const capability = s.Scan || s.RFID || s.Device || s.Codes || s.Detection || s.Measurement || s.Sensor || s.Range || s.Parameter || t(locale, 'pp.compare.fbCapability');
            const rugged = s.Rugged || s.Temp || s.Lead || s.Housing || s.Rating || s.Output || s.Data || t(locale, 'pp.compare.fbRugged');
            return (<tr><td>{p.name}</td><td>{p.type}</td><td>{specVal(locale, capability)}</td><td>{specVal(locale, rugged)}</td></tr>);
          })}
        </tbody>
      </table></div>
    </div></section>

    <section class="cta-band"><div class="container"><div class="cta-inner">
      <div><h2>{t(locale, 'main.261')}</h2><p>{t(locale, 'main.262')}</p></div>
      <div class="cta-actions">
        <a class="button button-primary" href={localizeUrl(locale, '/contact-sales.html')}>{t(locale, 'main.256')} <i class="fa-solid fa-arrow-right"></i></a>
        <a class="button button-outline" href={localizeUrl(locale, `/request-quote.html?productCategory=${category}`)}>{t(locale, 'rfq.cta')} <i class="fa-solid fa-arrow-right"></i></a>
      </div>
    </div></div></section>
  </main>
  <Footer slot="footer" locale={locale} />
</Layout>
