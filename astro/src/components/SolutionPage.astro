---
import Layout from '../layouts/Layout.astro';
import Footer from './Footer.astro';
import { t, localizeUrl, type Locale } from '../i18n';
import { canonicalUrl } from '../utils/seo';
import { createOrganizationJsonLd, breadcrumbFromHome } from '../utils/structured-data';
import { getSolution } from '../data/solutions';
// Content + meta come from the Solution data model (src/data/solutions.ts). The section/card
// MARKUP is kept literal here (byte-identical to the deployed page) — Astro strips whitespace
// between .map() siblings, which would change inter-element spacing, so the layout stays literal.
// A fully-generic multi-solution body renderer is a documented next step (see docs/SOLUTIONS_GUIDE.md).
interface Props { locale: Locale; slug?: string; }
const { locale, slug = 'automated-vision-inspection' } = Astro.props;
const sol = getSolution(slug);
if (!sol) throw new Error(`[SolutionPage] unknown solution slug "${slug}"`);
const path = sol.path;
const hero = sol.hero!;
const [tabCap, tabArch, tabWf, tabDep] = sol.tabs!;
const [capSec, archSec, wfSec] = sol.sections!;
const cap = capSec.cards;
const arch = archSec.cards;
const wf = wfSec.cards;
const cta = sol.cta!;
const structuredData = [
  createOrganizationJsonLd(),
  breadcrumbFromHome(locale, [{ name: t(locale, sol.breadcrumbKey!), url: canonicalUrl(locale, path) }]),
];
---
<Layout
  locale={locale}
  path={path}
  title={t(locale, sol.titleKey)}
  description={t(locale, sol.descKey!)}
  pageCss={["/product-page.css", "/solution-page.css", "/mobile-navigation.css"]}
  structuredData={structuredData}
>
  <main>
    <section class="solution-hero">
      <div class="container">
        <div class="solution-hero-grid">
          <div>
            <span class="eyebrow">{t(locale, hero.eyebrowKey)}</span>
            <h1>{t(locale, hero.titleKey)}</h1>
            <p>{t(locale, hero.descKey)}</p>
          </div>
          <aside class="solution-panel">
            <span>{t(locale, hero.panel.labelKey)}</span>
            <strong>{t(locale, hero.panel.valueKey)}</strong>
            <p>{t(locale, hero.panel.descKey)}</p>
          </aside>
        </div>
      </div>
    </section>

    <nav class="solution-tabs" aria-label="Solution page sections">
      <div class="container">
        <a href={tabCap.href}>{t(locale, tabCap.labelKey)}</a>
        <a href={tabArch.href}>{t(locale, tabArch.labelKey)}</a>
        <a href={tabWf.href}>{t(locale, tabWf.labelKey)}</a>
        <a href={tabDep.href}>{t(locale, tabDep.labelKey)}</a>
      </div>
    </nav>

    <section class="solution-section" id={capSec.id}>
      <div class="container">
        <div class="solution-head">
          <div>
            <span class="eyebrow">{t(locale, capSec.eyebrowKey)}</span>
            <h2>{t(locale, capSec.titleKey)}</h2>
          </div>
          <p>{t(locale, capSec.introKey)}</p>
        </div>
        <div class="capability-grid">
          <article class="capability-card">
            <i class={cap[0].icon}></i>
            <h3>{t(locale, cap[0].titleKey)}</h3>
            <p>{t(locale, cap[0].descKey)}</p>
          </article>
          <article class="capability-card">
            <i class={cap[1].icon}></i>
            <h3>{t(locale, cap[1].titleKey)}</h3>
            <p>{t(locale, cap[1].descKey)}</p>
          </article>
          <article class="capability-card">
            <i class={cap[2].icon}></i>
            <h3>{t(locale, cap[2].titleKey)}</h3>
            <p>{t(locale, cap[2].descKey)}</p>
          </article>
          <article class="capability-card">
            <i class={cap[3].icon}></i>
            <h3>{t(locale, cap[3].titleKey)}</h3>
            <p>{t(locale, cap[3].descKey)}</p>
          </article>
        </div>
      </div>
    </section>

    <section class="solution-section dark" id={archSec.id}>
      <div class="container">
        <div class="solution-head">
          <div>
            <span class="eyebrow">{t(locale, archSec.eyebrowKey)}</span>
            <h2>{t(locale, archSec.titleKey)}</h2>
          </div>
          <p>{t(locale, archSec.introKey)}</p>
        </div>
        <div class="architecture-grid">
          <div class="architecture-visual" aria-label={t(locale, archSec.visualAriaKey!)}></div>
          <div class="capability-grid">
            <article class="architecture-card">
              <h3>{t(locale, arch[0].titleKey)}</h3>
              <p>{t(locale, arch[0].descKey)}</p>
            </article>
            <article class="architecture-card">
              <h3>{t(locale, arch[1].titleKey)}</h3>
              <p>{t(locale, arch[1].descKey)}</p>
            </article>
            <article class="architecture-card">
              <h3>{t(locale, arch[2].titleKey)}</h3>
              <p>{t(locale, arch[2].descKey)}</p>
            </article>
            <article class="architecture-card">
              <h3>{t(locale, arch[3].titleKey)}</h3>
              <p>{t(locale, arch[3].descKey)}</p>
            </article>
          </div>
        </div>
      </div>
    </section>

    <section class="solution-section alt" id={wfSec.id}>
      <div class="container">
        <div class="solution-head">
          <div>
            <span class="eyebrow">{t(locale, wfSec.eyebrowKey)}</span>
            <h2>{t(locale, wfSec.titleKey)}</h2>
          </div>
          <p>{t(locale, wfSec.introKey)}</p>
        </div>
        <div class="workflow-grid">
          <article class="workflow-step">
            <i class={wf[0].icon}></i>
            <h3>{t(locale, wf[0].titleKey)}</h3>
            <p>{t(locale, wf[0].descKey)}</p>
          </article>
          <article class="workflow-step">
            <i class={wf[1].icon}></i>
            <h3>{t(locale, wf[1].titleKey)}</h3>
            <p>{t(locale, wf[1].descKey)}</p>
          </article>
          <article class="workflow-step">
            <i class={wf[2].icon}></i>
            <h3>{t(locale, wf[2].titleKey)}</h3>
            <p>{t(locale, wf[2].descKey)}</p>
          </article>
        </div>
      </div>
    </section>

    <section class="solution-cta" id={cta.id}>
      <div class="container">
        <div class="solution-cta-inner">
          <div>
            <h2>{t(locale, cta.titleKey)}</h2>
            <p>{t(locale, cta.descKey)}</p>
          </div>
          <a class="button button-primary" href={localizeUrl(locale, cta.href)}>{t(locale, cta.buttonKey)} <i class="fa-solid fa-arrow-right"></i></a>
        </div>
      </div>
    </section>
  </main>
  <Footer slot="footer" locale={locale} />
  <script is:inline>
    (() => {
      const navItems = Array.from(document.querySelectorAll(".nav-item"));
      const closeDelay = 520;
      const isTouchNavigation = () => window.matchMedia("(hover: none)").matches;
      const closeItem = (item) => {
        window.clearTimeout(item.closeTimer);
        item.closeTimer = window.setTimeout(() => {
          item.classList.remove("is-open");
          item.querySelectorAll(".mega-link-group.is-open").forEach((group) => group.classList.remove("is-open"));
        }, closeDelay);
      };
      const setActiveGroup = (groups, activeGroup) => groups.forEach((group) => group.classList.toggle("is-open", group === activeGroup));
      const openItem = (item, groups) => {
        navItems.forEach((otherItem) => {
          if (otherItem !== item) {
            window.clearTimeout(otherItem.closeTimer);
            otherItem.classList.remove("is-open");
            otherItem.querySelectorAll(".mega-link-group.is-open").forEach((group) => group.classList.remove("is-open"));
          }
        });
        window.clearTimeout(item.closeTimer);
        item.classList.add("is-open");
        if (groups.length && !groups.some((group) => group.classList.contains("is-open"))) setActiveGroup(groups, groups[0]);
      };
      navItems.forEach((item) => {
        const menu = item.querySelector(".mega-menu");
        if (!menu) return;
        const groups = Array.from(item.querySelectorAll(".mega-link-group"));
        const trigger = item.querySelector(".nav-trigger");
        trigger?.addEventListener("click", (event) => {
          if (isTouchNavigation() && !item.classList.contains("is-open")) { event.preventDefault(); openItem(item, groups); }
        });
        item.addEventListener("pointerenter", () => openItem(item, groups));
        item.addEventListener("pointerleave", () => closeItem(item));
        menu.addEventListener("pointerenter", () => openItem(item, groups));
        menu.addEventListener("pointerleave", () => closeItem(item));
        groups.forEach((group) => {
          group.addEventListener("pointerenter", () => { openItem(item, groups); setActiveGroup(groups, group); });
          group.addEventListener("focusin", () => { openItem(item, groups); setActiveGroup(groups, group); });
        });
      });
    })();
  </script>
</Layout>
