---
// One `.mega-link-group`: the primary `.mega-link` plus its `.submenu` flyout.
// DOM must stay identical to the legacy Header markup — the mobile drawer
// (public/mobile-navigation.js) reads `:scope > .mega-link` and `:scope > .submenu > a`.
import { t, localizeUrl, type Locale } from '../../i18n';
import type { MegaLinkGroup } from '../../types/navigation';
interface Props { locale: Locale; group: MegaLinkGroup; }
const { locale, group } = Astro.props;
const { link, submenu } = group;
const submenuClass = submenu.intro
  ? 'submenu submenu--intro'
  : submenu.blurbKey
    ? 'submenu submenu--solution'
    : 'submenu';
---
<div class="mega-link-group">
    <a class="mega-link" href={localizeUrl(locale, link.href)}><span><strong>{t(locale, link.titleKey)}</strong><span>{t(locale, link.descKey)}</span></span><i class="fa-solid fa-chevron-right"></i></a>
    <div class={submenuClass} style={`--submenu-image: url('${submenu.image}')`}>
        {submenu.blurbKey && <p class="submenu-intro">{t(locale, submenu.blurbKey)}</p>}
        {submenu.blurbKey
            ? <div class="submenu-caps">
                {submenu.links.map((l) => (
                    <div class="submenu-cap"><strong>{l.titleKey ? t(locale, l.titleKey) : l.titleText}</strong><span>{t(locale, l.descKey)}</span></div>
                ))}
              </div>
            : submenu.links.map((l) => (
                <a href={localizeUrl(locale, l.href)}><strong>{l.titleKey ? t(locale, l.titleKey) : l.titleText}</strong><span>{t(locale, l.descKey)}</span></a>
              ))}
    </div>
</div>
