---
import { t, localizeUrl, type Locale } from '../i18n';
import PaymentMethods from './PaymentMethods.astro';
import CompanyAddresses from './CompanyAddresses.astro';
import { FOOTER_NAV } from '../data/navigation';
interface Props { locale: Locale; }
const { locale } = Astro.props;
// Footer link columns are data-driven from FOOTER_NAV (src/data/navigation.ts) — edit links
// there. Layout unchanged: col 2 stacks Products + Solutions; col 4 keeps the Company links
// plus the contact/shop links and PaymentMethods. The `{i > 0 && ' '}` keeps the inter-link
// whitespace byte-identical to the previous hand-written markup (no public/ re-render churn).
const [products, solutions, support, company] = FOOTER_NAV;
---
<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div>
        <h3 class="footer-brand-name">GYUTRON</h3>
        <p>{t(locale, "main.331")}</p>
        <CompanyAddresses locale={locale} />
      </div>
      <div>
        <h4>{t(locale, products.labelKey!)}</h4>
        {products.links.map((l, i) => (
          <Fragment>{i > 0 && ' '}<a href={localizeUrl(locale, l.href!)}>{t(locale, l.labelKey!)}</a></Fragment>
        ))}
        <h4 style="margin-top:28px">{t(locale, solutions.labelKey!)}</h4>
        {solutions.links.map((l, i) => (
          <Fragment>{i > 0 && ' '}<a href={localizeUrl(locale, l.href!)}>{t(locale, l.labelKey!)}</a></Fragment>
        ))}
      </div>
      <div>
        <h4>{t(locale, support.labelKey!)}</h4>
        {support.links.map((l, i) => (
          <Fragment>{i > 0 && ' '}<a href={localizeUrl(locale, l.href!)}>{t(locale, l.labelKey!)}</a></Fragment>
        ))}
      </div>
      <div>
        <h4>{t(locale, company.labelKey!)}</h4>
        {company.links.map((l, i) => (
          <Fragment>{i > 0 && ' '}<a href={localizeUrl(locale, l.href!)}>{t(locale, l.labelKey!)}</a></Fragment>
        ))}
        <a href="mailto:info@gyutron.com">info@gyutron.com</a>
        <a href="https://wa.me/85269509801">WhatsApp: +852 69509801</a>
        <a href="https://shop.gyutron.com">{t(locale, "main.335")}</a>
        <PaymentMethods />
      </div>
    </div>
    <div class="footer-bottom">
      <span>{t(locale, "main.267")}</span>
      <div class="socials" aria-label="Social media placeholders">
        <span aria-label="Facebook" title="Facebook"><i class="fa-brands fa-facebook-f"></i></span>
        <span aria-label="YouTube" title="YouTube"><i class="fa-brands fa-youtube"></i></span>
        <span aria-label="LinkedIn" title="LinkedIn"><i class="fa-brands fa-linkedin-in"></i></span>
        <span aria-label="TikTok" title="TikTok"><i class="fa-brands fa-tiktok"></i></span>
      </div>
    </div>
  </div>
</footer>
