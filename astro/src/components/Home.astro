                        <p>{t(locale, "home.x.about.body")}</p>
                        <ul class="hx-values">
                            {values.map((v) => (
                                <li class="hx-value">
                                    <i class={`fa-solid ${v.icon}`}></i>
                                    <div><strong>{t(locale, v.t)}</strong><span>{t(locale, v.d)}</span></div>
                                </li>
                            ))}
                        </ul>
                    </div>
                    <div class="hx-about__media" aria-hidden="true">
                        {aboutImages.map((src) => (<div class="hx-about__img"><img src={src} alt="" loading="lazy" /></div>))}
