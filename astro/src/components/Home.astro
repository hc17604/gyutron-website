            </div>
        </section>

        <section class="proof-band">
            <div class="container">
                <div class="proof-grid">
                    <div class="proof-item">
                        <strong data-count="4">4</strong>
                        <span>{t(locale, "main.445")}</span>
                    </div>
                    <div class="proof-item">
                        <strong data-count="18">18</strong>
                        <span>{t(locale, "main.446")}</span>
                    </div>
                    <div class="proof-item">
                        <strong data-count="90" data-suffix="+">90+</strong>
                        <span>{t(locale, "main.361")}</span>
                    </div>
                    <div class="proof-item">
                        <strong data-count="3">3</strong>
                        <span>{t(locale, "main.362")}</span>
                    </div>
