---
import Layout from '../layouts/Layout.astro';
import { t, localizeUrl, type Locale } from '../i18n';
import TabCarousel from './TabCarousel.astro';
import HeroSlider from './HeroSlider.astro';
import Footer from './Footer.astro';
import { getLatestNews } from '../data/news';
import { PARTNERS } from '../data/partners';
interface Props { locale: Locale; }
const { locale } = Astro.props;
const path = '/';
const industries = [
  'home.tc.auto.label', 'home.tc.elec.label', 'hero.s1.semi', 'home.tc.logistics.label',
  'home.tc.pharma.label', 'home.x.ind.energy', 'home.x.ind.food', 'home.x.ind.oem',
];
const procSteps = [
  { n: '01', t: 'home.x.proc.s1.t', d: 'home.x.proc.s1.d', icon: 'fa-comments' },
  { n: '02', t: 'home.x.proc.s2.t', d: 'home.x.proc.s2.d', icon: 'fa-drafting-compass' },
  { n: '03', t: 'home.x.proc.s3.t', d: 'home.x.proc.s3.d', icon: 'fa-plug-circle-check' },
  { n: '04', t: 'home.x.proc.s4.t', d: 'home.x.proc.s4.d', icon: 'fa-arrow-trend-up' },
];
const values = [
  { icon: 'fa-compass-drafting', t: 'home.x.val1.t', d: 'home.x.val1.d' },
  { icon: 'fa-certificate', t: 'home.x.val2.t', d: 'home.x.val2.d' },
  { icon: 'fa-earth-asia', t: 'home.x.val3.t', d: 'home.x.val3.d' },
  { icon: 'fa-handshake', t: 'home.x.val4.t', d: 'home.x.val4.d' },
];
const aboutImages = ['/nav-company-engineering-lab.png', '/nav-company-quality-bench.png', '/nav-company-overview.png'];
const news = getLatestNews(3);
---
<Layout locale={locale} path={path} title={t(locale, 'seo.index.title')} description={t(locale, 'seo.index.desc')} bodyClass="home" pageCss={["/global.css", "/hero-slider.css", "/home-sections.css", "/mobile-navigation.css"]}>
<noscript><style>body.home [data-reveal]{opacity:1 !important;transform:none !important;}</style></noscript>
<main>
        <HeroSlider locale={locale} />

        <section class="hx-trust" aria-label="Industries served">
            <div class="container">
                <p class="hx-trust__label">{t(locale, "home.x.trust.label")}</p>
                <div class="hx-marquee">
                    <ul class="hx-marquee__track">
                        {industries.map((k) => (<li class="hx-chip"><span class="hx-chip__tick"></span>{t(locale, k)}</li>))}
                        {industries.map((k) => (<li class="hx-chip" aria-hidden="true"><span class="hx-chip__tick"></span>{t(locale, k)}</li>))}
                    </ul>
                </div>
            </div>
        </section>

        <section class="section section-alt section-products" id="products">
            <div class="container">
                <div class="section-head">
                    <div>
                        <span class="eyebrow">{t(locale, "home.feat.eyebrow")}</span>
                        <h2>{t(locale, "home.feat.title")}</h2>
                    </div>
                    <p>{t(locale, "home.feat.sub")}</p>
                </div>

                <div class="feat-bar">
                    <div class="feat-industries">
                        <span class="feat-industries__label">{t(locale, "home.feat.tagsLabel")}</span>
                        <span class="feat-tag">{t(locale, "home.feat.tag1")}</span>
                        <span class="feat-tag">{t(locale, "home.feat.tag2")}</span>
                        <span class="feat-tag">{t(locale, "home.feat.tag3")}</span>
                        <span class="feat-tag">{t(locale, "home.feat.tag4")}</span>
                        <span class="feat-tag">{t(locale, "home.feat.tag5")}</span>
                    </div>
                    <a class="button button-primary" href={localizeUrl(locale, "/contact-sales.html")}>{t(locale, "home.feat.cta")} <i class="fa-solid fa-arrow-right"></i></a>
                </div>

                <div class="product-showcase">
                    <article class="feature-product" data-reveal>
                        <div class="feature-image">
                            <img src="/product-vision-cell.png" alt="Robot vision workcell on a production line">
                        </div>
                        <div class="product-body">
                            <span class="badge"><i class="fa-solid fa-robot"></i> {t(locale, "home.feat.f.badge")}</span>
                            <h3>{t(locale, "home.feat.f.title")}</h3>
                            <p>{t(locale, "home.feat.f.desc")}</p>
                            <ul class="spec-list">
                                <li><i class="fa-solid fa-gauge-high"></i> {t(locale, "home.feat.f.b1")}</li>
                                <li><i class="fa-solid fa-plug-circle-bolt"></i> {t(locale, "home.feat.f.b2")}</li>
                                <li><i class="fa-solid fa-shield-halved"></i> {t(locale, "home.feat.f.b3")}</li>
                            </ul>
                            <a class="link-arrow" href={localizeUrl(locale, "/vision-guided-robotics.html")}>{t(locale, "home.feat.f.cta")} <i class="fa-solid fa-arrow-right"></i></a>
                        </div>
                    </article>

                    <div class="compact-stack">
                        <article class="compact-product" data-reveal>
                            <div class="compact-image compact-image--vision">
                                <img src="/home-smart-camera-platform-line.png" alt={t(locale, "main.357")}>
                            </div>
                            <div class="product-body">
                                <span class="badge"><i class="fa-solid fa-eye"></i> {t(locale, "home.feat.c1.badge")}</span>
                                <h3>{t(locale, "home.feat.c1.title")}</h3>
                                <p>{t(locale, "home.feat.c1.desc")}</p>
                                <a class="link-arrow" href={localizeUrl(locale, "/automated-vision-inspection.html")}>{t(locale, "home.feat.c1.cta")} <i class="fa-solid fa-arrow-right"></i></a>
                            </div>
                        </article>

                        <article class="compact-product" data-reveal>
                            <div class="compact-image compact-image--data">
                                <img src="/home-data-capture-traceability.png" alt={t(locale, "main.359")}>
                            </div>
                            <div class="product-body">
                                <span class="badge"><i class="fa-solid fa-mobile-screen-button"></i> {t(locale, "home.feat.c2.badge")}</span>
                                <h3>{t(locale, "home.feat.c2.title")}</h3>
                                <p>{t(locale, "home.feat.c2.desc")}</p>
                                <a class="link-arrow" href={localizeUrl(locale, "/identification-traceability.html")}>{t(locale, "home.feat.c2.cta")} <i class="fa-solid fa-arrow-right"></i></a>
                            </div>
