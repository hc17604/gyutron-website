# GYUTRON brand site — example environment.
# Copy to `.env` (gitignored) and fill in as needed. The static site builds with NO env
# configured; every variable below has a safe default (mock / local / empty).

PUBLIC_SITE_URL=https://www.gyutron.com
PUBLIC_SITE_NAME=GYUTRON

# Future CRM integration (lead storage). Default: mock = in-memory, no external calls.
CRM_PROVIDER=mock
CRM_API_KEY=

# Future CMS integration (content source). Default: local = src/data + src/i18n.
CMS_PROVIDER=local
CMS_API_URL=
CMS_API_KEY=

# Future analytics. Leave blank to disable.
ANALYTICS_PROVIDER=
ANALYTICS_ID=

# Future agent / AI integration. Default: mock = no model is called.
AGENT_PROVIDER=mock
AGENT_API_KEY=

# Cloudflare Turnstile SITE key (public, baked into form pages at build time).
# Empty (default) = forms render WITHOUT the widget and the worker skips verification.
# Rollout order matters: set this + rebuild + deploy FIRST, only then set the worker
# secret TURNSTILE_SECRET_KEY (see docs/cloudflare-deployment.md §5).
PUBLIC_TURNSTILE_SITE_KEY=

# ---------------------------------------------------------------------------------------
# The contact form is handled by the Cloudflare Worker (src/contact-handler.mjs → Resend).
# Those are WORKER SECRETS set in the Cloudflare dashboard — NOT build-time vars here:
#   RESEND_API_KEY, CONTACT_FROM_EMAIL
#
# Do NOT add payment / order / cart / inventory / logistics variables to this file. The
# storefront (shop.gyutron.com) is a separate project and is out of scope for the brand site.
